# ─── LLM (DashScope / OpenAI-compatible) ────────────────────────────────────
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ─── Embedding ───────────────────────────────────────────────────────────────
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# ─── Rerank (Qwen3 / DashScope gte-rerank) ───────────────────────────────────
RERANK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
RERANK_MODEL=gte-rerank
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_TOP_N=5
RERANK_CANDIDATE_K=20

# ─── Milvus ───────────────────────────────────────────────────────────────────
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=medqa_chunks

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://medqa:medqa123@localhost:5432/medqa

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600
REDIS_DOC_TTL=7200

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─── BM25 ─────────────────────────────────────────────────────────────────────
BM25_MODEL_PATH=./bm25_model.pkl

# ─── Chunking ─────────────────────────────────────────────────────────────────
L1_CHUNK_SIZE=1200
L1_CHUNK_OVERLAP=240
L2_CHUNK_SIZE=600
L2_CHUNK_OVERLAP=120
L3_CHUNK_SIZE=300
L3_CHUNK_OVERLAP=60

# ─── RAG ──────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=20
RELEVANCE_SCORE_THRESHOLD=0.5
MERGE_THRESHOLD=0.5

# ─── Session Memory ───────────────────────────────────────────────────────────
SUMMARY_THRESHOLD=20
SUMMARY_WINDOW=10

# ─── App ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
MAX_UPLOAD_SIZE_MB=50
